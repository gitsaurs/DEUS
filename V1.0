<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <meta name="description" content="DEUS – Your divine companion for faith, prayer, Christian news, spiritual growth, and sacred products. Join 1000+ believers today." />
  <meta name="keywords" content="Christianity, Christian app, Bible, prayer, faith, Jesus, Church, Catholic, Protestant, spiritual growth, Christian products" />
  <meta name="author" content="DEUS App" />
  <meta property="og:title" content="DEUS – Your Divine Companion" />
  <meta property="og:description" content="Faith, prayer, news, AI chat, and sacred products — all in one place." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://deusapp.com" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://deusapp.com" />
  <title>DEUS – Your Divine Companion</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;500;600;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet" />

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/TextPlugin.min.js"></script>

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <script>
    tailwind.config = {
      darkMode: ['class', '[data-theme="dark"]'],
      theme: {
        extend: {
          colors: {
            gold: { 50:'#fffbeb', 100:'#fef3c7', 200:'#fde68a', 300:'#fcd34d', 400:'#fbbf24', 500:'#D4AF37', 600:'#B8960C', 700:'#92740A', 800:'#6B5507', 900:'#453703' },
            divine: '#D4AF37',
            cream: '#FEFCF3',
          },
          fontFamily: {
            display: ['Cinzel Decorative', 'serif'],
            heading: ['Cinzel', 'serif'],
            body: ['Crimson Pro', 'serif'],
          },
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'glow': 'glow 2s ease-in-out infinite alternate',
            'shimmer': 'shimmer 3s linear infinite',
            'cross-rotate': 'crossRotate 20s linear infinite',
          },
          keyframes: {
            float: { '0%,100%': {transform:'translateY(0px)'}, '50%': {transform:'translateY(-20px)'} },
            glow: { '0%': {boxShadow:'0 0 20px #D4AF3740'}, '100%': {boxShadow:'0 0 60px #D4AF3790, 0 0 100px #D4AF3740'} },
            shimmer: { '0%': {backgroundPosition:'-200% center'}, '100%': {backgroundPosition:'200% center'} },
            crossRotate: { '0%': {transform:'rotate(0deg)'}, '100%': {transform:'rotate(360deg)'} },
          }
        }
      }
    }
  </script>

  <style>
    :root {
      --gold: #D4AF37;
      --gold-light: #F0D060;
      --gold-dark: #B8960C;
      --bg: #FEFCF3;
      --bg-card: #FFFFFF;
      --text: #1a1208;
      --text-muted: #5a4a2a;
      --border: #e8d99a;
      --nav-bg: rgba(254,252,243,0.95);
    }
    [data-theme="dark"] {
      --bg: #0a0804;
      --bg-card: #14100a;
      --text: #F0D060;
      --text-muted: #c9a84c;
      --border: #3a2e0a;
      --nav-bg: rgba(10,8,4,0.95);
    }

    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Crimson Pro', serif;
      background: var(--bg);
      color: var(--text);
      transition: background 0.4s ease, color 0.4s ease;
      overflow-x: hidden;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 2px; }

    /* Gold shimmer text */
    .gold-shimmer {
      background: linear-gradient(90deg, var(--gold-dark), var(--gold), var(--gold-light), var(--gold), var(--gold-dark));
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 3s linear infinite;
    }

    /* Glass card */
    .glass {
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(212,175,55,0.2);
    }
    [data-theme="dark"] .glass {
      background: rgba(20,16,10,0.6);
      border: 1px solid rgba(212,175,55,0.25);
    }

    /* Divine button */
    .btn-divine {
      background: linear-gradient(135deg, #D4AF37, #F0D060, #B8960C);
      color: #1a1208;
      font-family: 'Cinzel', serif;
      font-weight: 600;
      letter-spacing: 0.08em;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
    }
    .btn-divine::before {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
      transition: left 0.5s ease;
    }
    .btn-divine:hover::before { left: 100%; }
    .btn-divine:hover { transform: translateY(-2px); box-shadow: 0 10px 40px rgba(212,175,55,0.5); }

    /* Nav */
    nav {
      background: var(--nav-bg);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(212,175,55,0.2);
      position: fixed; top:0; left:0; right:0; z-index:1000;
    }

    /* Hero */
    .hero-bg {
      background: radial-gradient(ellipse at 50% 0%, rgba(212,175,55,0.15) 0%, transparent 70%),
                  radial-gradient(ellipse at 100% 100%, rgba(212,175,55,0.08) 0%, transparent 50%),
                  var(--bg);
    }
    [data-theme="dark"] .hero-bg {
      background: radial-gradient(ellipse at 50% 0%, rgba(212,175,55,0.2) 0%, transparent 70%),
                  radial-gradient(ellipse at 100% 100%, rgba(212,175,55,0.1) 0%, transparent 50%),
                  var(--bg);
    }

    /* Particle canvas */
    #particleCanvas { position:absolute; top:0; left:0; pointer-events:none; }

    /* Cross decorative */
    .cross-deco {
      position: absolute;
      opacity: 0.04;
      font-size: 300px;
      color: var(--gold);
      user-select: none;
      animation: crossRotate 40s linear infinite;
    }

    /* Feature card hover */
    .feature-card {
      border: 1px solid var(--border);
      background: var(--bg-card);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      cursor: pointer;
    }
    .feature-card:hover {
      transform: translateY(-8px) scale(1.02);
      border-color: var(--gold);
      box-shadow: 0 20px 60px rgba(212,175,55,0.2);
    }

    /* Theme toggle */
    .theme-toggle {
      width: 52px; height: 28px;
      background: linear-gradient(135deg, #D4AF37, #F0D060);
      border-radius: 14px;
      position: relative;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .theme-toggle::after {
      content: '';
      position: absolute;
      top: 3px; left: 3px;
      width: 22px; height: 22px;
      border-radius: 50%;
      background: white;
      transition: all 0.3s ease;
    }
    [data-theme="dark"] .theme-toggle::after { left: 27px; background: #0a0804; }

    /* Pricing card */
    .pricing-popular {
      border: 2px solid var(--gold);
      transform: scale(1.05);
      box-shadow: 0 20px 80px rgba(212,175,55,0.25);
    }

    /* Bottom nav (mobile) */
    .bottom-nav {
      position: fixed; bottom:0; left:0; right:0; z-index:999;
      background: var(--nav-bg);
      backdrop-filter: blur(20px);
      border-top: 1px solid rgba(212,175,55,0.2);
      padding: 8px 0 env(safe-area-inset-bottom);
    }

    /* Quote block */
    .quote-card::before {
      content: '"';
      font-family: 'Cinzel Decorative', serif;
      font-size: 80px;
      color: var(--gold);
      opacity: 0.3;
      position: absolute;
      top: -10px; left: 10px;
      line-height: 1;
    }

    /* News card */
    .news-img-wrap { overflow: hidden; border-radius: 12px; }
    .news-img-wrap img { transition: transform 0.5s ease; }
    .news-card:hover .news-img-wrap img { transform: scale(1.08); }

    /* Loader */
    #loader {
      position: fixed; inset:0; z-index:9999;
      background: var(--bg);
      display: flex; align-items:center; justify-content:center;
      flex-direction: column; gap: 16px;
    }
    .loader-cross {
      font-size: 60px; color: var(--gold);
      animation: float 1.5s ease-in-out infinite;
    }
    .loader-bar {
      width: 200px; height: 2px;
      background: rgba(212,175,55,0.2);
      border-radius: 1px; overflow: hidden;
    }
    .loader-fill {
      height: 100%;
      background: linear-gradient(90deg, #D4AF37, #F0D060);
      border-radius: 1px;
      animation: loadFill 2s ease forwards;
    }
    @keyframes loadFill { from{width:0} to{width:100%} }

    /* Section divider */
    .divider {
      display: flex; align-items: center; gap: 16px;
      color: var(--gold); opacity: 0.5;
    }
    .divider::before, .divider::after {
      content: ''; flex:1; height:1px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }

    /* Floating particles */
    .particle {
      position: absolute;
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--gold);
      opacity: 0;
      animation: particleFade 4s ease-in-out infinite;
    }
    @keyframes particleFade {
      0%,100%{opacity:0;transform:translateY(0) scale(0)}
      50%{opacity:0.6;transform:translateY(-60px) scale(1)}
    }

    /* Toast */
    .toast {
      position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);
      background: linear-gradient(135deg, #D4AF37, #F0D060);
      color: #1a1208; padding: 10px 24px; border-radius: 24px;
      font-family: 'Cinzel', serif; font-size: 13px; font-weight: 600;
      z-index: 9998; opacity: 0; transition: opacity 0.3s;
    }

    /* Stats counter */
    .stat-num { font-family: 'Cinzel Decorative', serif; }

    /* Responsive helpers */
    @media (max-width: 640px) {
      .hero-title { font-size: clamp(2rem, 8vw, 3.5rem); }
      .hide-mobile { display: none !important; }
    }
    @media (min-width: 641px) {
      .show-mobile-only { display: none !important; }
      .bottom-nav { display: none !important; }
    }

    .section-enter { opacity: 0; transform: translateY(40px); }

    /* AI Chat bubble */
    .chat-bubble-ai {
      background: linear-gradient(135deg, rgba(212,175,55,0.15), rgba(212,175,55,0.05));
      border: 1px solid rgba(212,175,55,0.3);
      border-radius: 18px 18px 18px 4px;
    }
    .chat-bubble-user {
      background: linear-gradient(135deg, #D4AF37, #B8960C);
      color: #1a1208;
      border-radius: 18px 18px 4px 18px;
    }

    /* Scroll indicator */
    .scroll-indicator {
      width: 30px; height: 50px;
      border: 2px solid rgba(212,175,55,0.5);
      border-radius: 15px;
      position: relative;
    }
    .scroll-dot {
      width: 6px; height: 6px;
      background: var(--gold);
      border-radius: 50%;
      position: absolute;
      left: 50%; top: 8px;
      transform: translateX(-50%);
      animation: scrollDot 2s ease-in-out infinite;
    }
    @keyframes scrollDot { 0%,100%{top:8px;opacity:1} 50%{top:30px;opacity:0.3} }

    /* Product card */
    .product-card { transition: all 0.3s ease; }
    .product-card:hover { transform: translateY(-6px); }
    .product-badge {
      background: linear-gradient(135deg, #D4AF37, #F0D060);
      color: #1a1208; font-family: 'Cinzel', serif;
      font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
    }

    /* Church map pin */
    .map-pin { animation: float 3s ease-in-out infinite; }

    /* Stars */
    .star-field {
      position: absolute; inset: 0; overflow: hidden; pointer-events: none;
    }
    .star {
      position: absolute; width: 2px; height: 2px;
      background: var(--gold); border-radius: 50%;
      animation: twinkle var(--d, 3s) ease-in-out infinite;
      opacity: var(--o, 0.4);
    }
    @keyframes twinkle { 0%,100%{opacity:var(--o)} 50%{opacity:0.1} }
  </style>
</head>
<body>

<!-- Loader -->
<div id="loader">
  <div class="loader-cross">✝</div>
  <p class="gold-shimmer" style="font-family:'Cinzel Decorative',serif; font-size:28px; letter-spacing:0.3em;">DEUS</p>
  <div class="loader-bar"><div class="loader-fill"></div></div>
  <p style="font-family:'Crimson Pro',serif; font-size:14px; opacity:0.5; margin-top:8px;">Your Divine Companion</p>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<!-- ═══════════════════════ NAVIGATION ═══════════════════════ -->
<nav id="mainNav">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="index.html" class="flex items-center gap-2 group">
      <span style="font-size:22px; color:var(--gold);">✝</span>
      <span style="font-family:'Cinzel Decorative',serif; font-size:20px; font-weight:700;" class="gold-shimmer">DEUS</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hide-mobile flex items-center gap-6">
      <a href="#features" class="nav-link" style="font-family:'Cinzel',serif; font-size:13px; letter-spacing:0.05em;">Features</a>
      <a href="news.html" class="nav-link" style="font-family:'Cinzel',serif; font-size:13px; letter-spacing:0.05em;">News</a>
      <a href="products.html" class="nav-link" style="font-family:'Cinzel',serif; font-size:13px; letter-spacing:0.05em;">Shop</a>
      <a href="places.html" class="nav-link" style="font-family:'Cinzel',serif; font-size:13px; letter-spacing:0.05em;">Places</a>
      <a href="#pricing" class="nav-link" style="font-family:'Cinzel',serif; font-size:13px; letter-spacing:0.05em;">Pricing</a>
    </div>

    <!-- Right controls -->
    <div class="flex items-center gap-3">
      <!-- Theme Toggle -->
      <div class="theme-toggle" id="themeToggle" title="Toggle theme">
        <span style="position:absolute;top:50%;left:6px;transform:translateY(-50%);font-size:11px;z-index:1;">☀️</span>
        <span style="position:absolute;top:50%;right:6px;transform:translateY(-50%);font-size:11px;z-index:1;">🌙</span>
      </div>
      <a href="login.html" class="hide-mobile px-4 py-2 rounded-full btn-divine text-sm">Sign In</a>
      <a href="#" id="menuBtn" class="show-mobile-only" style="color:var(--gold);font-size:22px;"><i class="fas fa-bars"></i></a>
    </div>
  </div>
</nav>

<!-- Mobile Menu -->
<div id="mobileMenu" style="display:none; position:fixed; inset:0; z-index:998; background:var(--bg); padding-top:80px;">
  <div class="flex flex-col items-center gap-8 pt-8">
    <a href="#features" class="mobile-menu-link" style="font-family:'Cinzel',serif; font-size:22px; color:var(--gold);" onclick="closeMobile()">Features</a>
    <a href="news.html" class="mobile-menu-link" style="font-family:'Cinzel',serif; font-size:22px; color:var(--text);" onclick="closeMobile()">News</a>
    <a href="products.html" class="mobile-menu-link" style="font-family:'Cinzel',serif; font-size:22px; color:var(--text);" onclick="closeMobile()">Shop</a>
    <a href="places.html" class="mobile-menu-link" style="font-family:'Cinzel',serif; font-size:22px; color:var(--text);" onclick="closeMobile()">Sacred Places</a>
    <a href="#pricing" class="mobile-menu-link" style="font-family:'Cinzel',serif; font-size:22px; color:var(--text);" onclick="closeMobile()">Pricing</a>
    <div class="divider w-48"><i class="fas fa-cross" style="font-size:12px;"></i></div>
    <a href="login.html" class="btn-divine px-8 py-3 rounded-full text-base">Begin Your Journey</a>
    <a href="#" onclick="closeMobile()" style="color:var(--text-muted); font-size:13px; margin-top:20px;"><i class="fas fa-times"></i> Close</a>
  </div>
</div>

<!-- ═══════════════════════ HERO SECTION ═══════════════════════ -->
<section class="hero-bg min-h-screen flex flex-col items-center justify-center relative overflow-hidden pt-20 pb-32" id="hero">

  <!-- Star field -->
  <div class="star-field" id="starField"></div>

  <!-- Decorative cross bg -->
  <div class="cross-deco" style="top:-80px; right:-80px; font-size:400px; font-family:serif;">✝</div>
  <div class="cross-deco" style="bottom:-100px; left:-100px; font-size:350px; animation-direction:reverse; opacity:0.03;">✝</div>

  <!-- Floating particles -->
  <div id="heroParticles"></div>

  <div class="max-w-4xl mx-auto px-6 text-center relative z-10">

    <!-- Badge -->
    <div id="heroBadge" class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8 opacity-0"
         style="border:1px solid rgba(212,175,55,0.4);">
      <span style="width:8px;height:8px;border-radius:50%;background:#4ade80;display:inline-block;animation:pulse 2s infinite;"></span>
      <span style="font-family:'Cinzel',serif; font-size:11px; letter-spacing:0.1em; color:var(--gold);">NOW LIVE · FREE 5-DAY TRIAL</span>
    </div>

    <!-- Main title -->
    <h1 class="hero-title mb-4 opacity-0" id="heroTitle"
        style="font-family:'Cinzel Decorative',serif; font-size:clamp(3rem,10vw,5.5rem); font-weight:900; line-height:1.1; letter-spacing:0.05em;">
      <span class="gold-shimmer">DEUS</span>
    </h1>

    <p class="opacity-0" id="heroSub"
       style="font-family:'Cinzel',serif; font-size:clamp(1rem,3vw,1.4rem); letter-spacing:0.15em; color:var(--text-muted); margin-bottom:24px;">
      YOUR DIVINE COMPANION
    </p>

    <p class="opacity-0 max-w-2xl mx-auto mb-10" id="heroDesc"
       style="font-family:'Crimson Pro',serif; font-size:clamp(1.1rem,2.5vw,1.3rem); line-height:1.8; color:var(--text-muted);">
      Deepen your faith with AI-powered spiritual guidance, sacred news, holy places, prayer communities, and exclusive Christian products — all in one divine space.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center opacity-0" id="heroCTAs">
      <a href="register.html" class="btn-divine px-8 py-4 rounded-full text-base w-full sm:w-auto text-center"
         style="font-family:'Cinzel',serif; letter-spacing:0.08em;">
        ✝ &nbsp; Begin Free Trial
      </a>
      <a href="#features" class="px-8 py-4 rounded-full w-full sm:w-auto text-center"
         style="border:1px solid var(--gold); color:var(--gold); font-family:'Cinzel',serif; font-size:14px; letter-spacing:0.08em; transition:all 0.3s;">
        Explore Features
      </a>
    </div>

    <!-- Trust line -->
    <p class="mt-6 opacity-0" id="heroTrust"
       style="font-size:13px; color:var(--text-muted); font-family:'Crimson Pro',serif;">
      5 days free · €0.49/day after · Cancel anytime
    </p>

    <!-- Scroll indicator -->
    <div class="flex flex-col items-center mt-16 opacity-0" id="scrollInd">
      <div class="scroll-indicator"><div class="scroll-dot"></div></div>
      <p style="font-size:11px; letter-spacing:0.15em; color:var(--text-muted); margin-top:8px; font-family:'Cinzel',serif;">SCROLL</p>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="absolute bottom-0 left-0 right-0" id="statsBar"
       style="background:linear-gradient(90deg, rgba(212,175,55,0.1), rgba(212,175,55,0.05), rgba(212,175,55,0.1)); border-top:1px solid rgba(212,175,55,0.2); padding:16px 24px;">
    <div class="max-w-4xl mx-auto flex justify-around items-center flex-wrap gap-4">
      <div class="text-center">
        <div class="stat-num gold-shimmer" style="font-size:28px;">1K+</div>
        <div style="font-size:11px; letter-spacing:0.1em; color:var(--text-muted); font-family:'Cinzel',serif;">BELIEVERS</div>
      </div>
      <div style="width:1px; height:40px; background:rgba(212,175,55,0.3);" class="hide-mobile"></div>
      <div class="text-center">
        <div class="stat-num gold-shimmer" style="font-size:28px;">50+</div>
        <div style="font-size:11px; letter-spacing:0.1em; color:var(--text-muted); font-family:'Cinzel',serif;">SACRED PLACES</div>
      </div>
      <div style="width:1px; height:40px; background:rgba(212,175,55,0.3);" class="hide-mobile"></div>
      <div class="text-center">
        <div class="stat-num gold-shimmer" style="font-size:28px;">24/7</div>
        <div style="font-size:11px; letter-spacing:0.1em; color:var(--text-muted); font-family:'Cinzel',serif;">AI GUIDANCE</div>
      </div>
      <div style="width:1px; height:40px; background:rgba(212,175,55,0.3);" class="hide-mobile"></div>
      <div class="text-center">
        <div class="stat-num gold-shimmer" style="font-size:28px;">5★</div>
        <div style="font-size:11px; letter-spacing:0.1em; color:var(--text-muted); font-family:'Cinzel',serif;">USER RATING</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ FEATURES SECTION ═══════════════════════ -->
<section id="features" class="py-24 px-6 relative">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-16 section-enter">
      <div class="divider mb-6"><i class="fas fa-cross" style="font-size:12px; color:var(--gold);"></i></div>
      <h2 style="font-family:'Cinzel Decorative',serif; font-size:clamp(1.8rem,5vw,2.8rem); margin-bottom:12px;">
        <span class="gold-shimmer">Divine Features</span>
      </h2>
      <p style="color:var(--text-muted); font-size:1.1rem; max-width:600px; margin:0 auto; line-height:1.8;">
