            <div class="chat-bubble-ai" style="padding:14px 18px; align-self:flex-start; display:flex; gap:4px; align-items:center;">
              <span style="width:8px;height:8px;border-radius:50%;background:var(--gold);animation:float 1s ease-in-out infinite;"></span>
              <span style="width:8px;height:8px;border-radius:50%;background:var(--gold);animation:float 1s ease-in-out infinite 0.2s;"></span>
              <span style="width:8px;height:8px;border-radius:50%;background:var(--gold);animation:float 1s ease-in-out infinite 0.4s;"></span>
            </div>
