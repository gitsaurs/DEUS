<!-- ═══════════════════════ JAVASCRIPT ═══════════════════════ -->
<script>
// ── Theme ──────────────────────────────────────────────
const html = document.documentElement;
const savedTheme = localStorage.getItem('deus-theme') || 'light';
html.setAttribute('data-theme', savedTheme);

document.getElementById('themeToggle').addEventListener('click', () => {
  const current = html.getAttribute('data-theme');
  const next = current === 'light' ? 'dark' : 'light';
  html.setAttribute('data-theme', next);
  localStorage.setItem('deus-theme', next);
  showToast(next === 'dark' ? '🌙 Dark Mode' : '☀️ Light Mode');
});

// ── Mobile Menu ─────────────────────────────────────────
document.getElementById('menuBtn').addEventListener('click', () => {
  const menu = document.getElementById('mobileMenu');
  menu.style.display = menu.style.display === 'none' ? 'flex' : 'none';
  document.body.style.overflow = menu.style.display === 'flex' ? 'hidden' : '';
});
function closeMobile() {
  document.getElementById('mobileMenu').style.display = 'none';
  document.body.style.overflow = '';
}

// ── Toast ───────────────────────────────────────────────
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.opacity = '1';
  setTimeout(() => t.style.opacity = '0', 2000);
}

// ── Star Field ──────────────────────────────────────────
const starField = document.getElementById('starField');
for (let i = 0; i < 60; i++) {
  const star = document.createElement('div');
  star.className = 'star';
  star.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;
    --d:${2+Math.random()*4}s;--o:${0.2+Math.random()*0.5};
    animation-delay:${Math.random()*4}s;`;
  starField.appendChild(star);
}

// ── Hero Particles ──────────────────────────────────────
const heroP = document.getElementById('heroParticles');
for (let i = 0; i < 20; i++) {
  const p = document.createElement('div');
  p.className = 'particle';
  p.style.cssText = `left:${Math.random()*100}%;top:${40+Math.random()*40}%;
    animation-delay:${Math.random()*4}s;animation-duration:${3+Math.random()*3}s;`;
  heroP.appendChild(p);
}

// ── GSAP Animations ─────────────────────────────────────
gsap.registerPlugin(ScrollTrigger, TextPlugin);

window.addEventListener('load', () => {
  // Hide loader
  setTimeout(() => {
    gsap.to('#loader', { opacity: 0, duration: 0.5, onComplete: () => {
      document.getElementById('loader').style.display = 'none';
    }});
  }, 2200);

  // Hero entrance
  const tl = gsap.timeline({ delay: 2.3 });
  tl.to('#heroBadge', { opacity:1, y:0, duration:0.6, ease:'back.out(1.7)' })
    .to('#heroTitle', { opacity:1, y:0, duration:0.8, ease:'back.out(1.4)' }, '-=0.3')
    .to('#heroSub', { opacity:1, y:0, duration:0.6 }, '-=0.4')
    .to('#heroDesc', { opacity:1, y:0, duration:0.6 }, '-=0.3')
    .to('#heroCTAs', { opacity:1, y:0, duration:0.6 }, '-=0.3')
    .to('#heroTrust', { opacity:1, duration:0.5 }, '-=0.2')
    .to('#scrollInd', { opacity:1, duration:0.5 }, '-=0.2');
});

// Section reveals
gsap.utils.toArray('.section-enter').forEach((el, i) => {
  gsap.to(el, {
    scrollTrigger: { trigger:el, start:'top 88%', toggleActions:'play none none reverse' },
    opacity:1, y:0, duration:0.7, delay:(i%4)*0.1, ease:'power3.out'
  });
});

// Nav scroll effect
ScrollTrigger.create({
  start: 'top -80',
  onUpdate: self => {
    const nav = document.getElementById('mainNav');
    nav.style.boxShadow = self.progress > 0 ? '0 4px 30px rgba(212,175,55,0.1)' : 'none';
  }
});

// ── Share Verse ─────────────────────────────────────────
function shareVerse() {
  const text = document.getElementById('verseText').textContent;
  if (navigator.share) {
    navigator.share({ title:'DEUS Daily Verse', text, url:window.location.href });
  } else {
    navigator.clipboard?.writeText(text);
    showToast('✝ Verse copied!');
  }
}

// ── Feature modal placeholder ───────────────────────────
function showFeatureModal(feature) {
  showToast('✦ Unlock with DEUS Premium');
}

// ── Nav link styles ─────────────────────────────────────
document.querySelectorAll('.nav-link').forEach(link => {
  link.style.cssText += 'color:var(--text-muted);transition:color 0.2s;text-decoration:none;';
  link.addEventListener('mouseenter', () => link.style.color = 'var(--gold)');
  link.addEventListener('mouseleave', () => link.style.color = 'var(--text-muted)');
});
</script>
</body>
</html>
