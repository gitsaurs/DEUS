              <div style="font-family:'Cinzel',serif; font-size:14px; font-weight:600; color:var(--gold);">DEUS AI Guide</div>
              <div style="font-size:11px; color:#4ade80; display:flex; align-items:center; gap:4px;">
                <span style="width:6px;height:6px;border-radius:50%;background:#4ade80;display:inline-block;"></span> Online
              </div>
            </div>
