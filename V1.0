          <div style="padding:16px 20px; background:linear-gradient(135deg, rgba(212,175,55,0.15), rgba(212,175,55,0.05)); border-bottom:1px solid rgba(212,175,55,0.2); display:flex; align-items:center; gap:12px;">
            <div style="width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,#D4AF37,#F0D060); display:flex; align-items:center; justify-content:center; font-size:18px;">✝</div>
